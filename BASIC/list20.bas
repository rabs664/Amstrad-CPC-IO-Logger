4 CLS
5 DIM gapen(17)
6 OUT &F9E0,0
7 DIM crtcreg(16)
8 lastcrtcreg=0
9 DIM otherreg(48)
10 FOR i=1 TO 16
20 crtcreg[i]=INP(&F9E0)
30 NEXT i
31 lastcrtcreg=INP(&F9E0)
35 FOR ii=1 TO 17
36 gapen[ii]=INP(&F9E0)
37 NEXT ii
38 lastgapen=INP(&F9E0)
39 gamode=INP(&F9E0):galrom=INP(&F9E0):gaurom=INP(&F9E0):gaint=INP(&F9E0)
50 gabanknum=INP(&F9E0):gabankconf=INP(&F9E0)
60 gaaddrnmode=INP(&F9E0):garomnum=INP(&F9E0)
70 errcode=INP(&F9E0)
90 LOCATE 1,1:PRINT "CRTC ":P=5
100 FOR reg=1 TO 16
110 LOCATE P,1:PRINT USING "##";reg-1
115 IF reg-1=lastcrtcreg THEN PEN 0:PAPER 1 ELSE PEN 1:PAPER 0
120 LOCATE P,2:PRINT HEX$(crtcreg[reg],2)
125 PEN 1:PAPER 0
130 P=P+3
140 NEXT reg
199 LOCATE 1,4:PRINT "PEN  ":p=5
200 FOR GAPEN=1 TO 17
210 LOCATE p,4:PRINT USING "##";GAPEN-1
220 IF gaPEN-1=lastgapen THEN PEN 0:PAPER 1 ELSE PEN 1:PAPER 0
230 LOCATE p,5:PRINT HEX$(gapen[GAPEN],2)
235 PEN 1:PAPER 0
240 p=p+3
250 NEXT GAPEN
270 LOCATE 1,7:PRINT "MODE"
280 LOCATE 1,8:PRINT HEX$(gamode,2)
290 LOCATE 7,7:PRINT "LROM"
300 LOCATE 7,8:PRINT HEX$(galrom,1)
310 LOCATE 13,7:PRINT "UROM"
320 LOCATE 13,8:PRINT HEX$(gaurom,1)
330 LOCATE 19,7:PRINT "INT"
340 LOCATE 19,8:PRINT HEX$(gaint,1)
350 LOCATE 1,10:PRINT "BANKNUM"
360 LOCATE 1,11:PRINT HEX$(gabanknum,1)
370 LOCATE 10,10:PRINT "BANKCONF"
380 LOCATE 10,11:PRINT HEX$(gabankconf,1)
400 LOCATE 1,13:PRINT "ADDRMODE"
410 LOCATE 1,14:PRINT HEX$(gaaddrmode,2)
420 LOCATE 11,13:PRINT "ROMNUM"
430 LOCATE 11,14:PRINT HEX$(garomnum,2)
440 LOCATE 1,16:PRINT "ERR"
450 LOCATE 1,17:PRINT HEX$(errcode,2)
