	(text_box "Amstrad CPC MX4 Connector\n\nFemale sockets on connector have pins reversed by orientation on the board so keep the same logical connections i.e. Pin 2 is Pin 49 and pin 3 is pin 48"
		(exclude_from_sim no)
		(at 16.51 15.24 0)
