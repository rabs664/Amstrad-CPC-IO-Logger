		(uuid "a8a5baef-6bbd-4aa5-b254-93dc64998057")
	)
	(text_box "IO Read Address Decode and IO Write Signal\n\n138 Decoders provide a low and high address byte selection signal (i.e. F8E0).\nThis is used to provide single active low signal for a port read when combined\nwith IORQ+RD.  "
		(exclude_from_sim no)
		(at 16.51 137.16 0)
		(size 288.29 124.46)
		(margins 0.9525 0.9525 0.9525 0.9525)
		(stroke
			(width 0)
			(type solid)
		)
		(fill
			(type none)
		)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left top)
		)
		(uuid "c8174841-b586-487c-8daa-63b66089b6fd")
	)
	(text_box "Bus Transcivers\n\nBus Transceiver provide voltage level shift from 5V to 3V3 and Bus isolation"
		(exclude_from_sim no)
		(at 308.61 15.24 0)
		(size 143.51 375.92)
		(margins 0.9525 0.9525 0.9525 0.9525)
